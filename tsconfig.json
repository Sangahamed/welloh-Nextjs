{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/db": ["./lib/db/src/index.ts"],
      "@workspace/db/*": ["./lib/db/src/*"],
      "@workspace/integrations-gemini-ai": ["./lib/integrations-gemini-ai/src/index.ts"],
      "@workspace/integrations-gemini-ai/*": ["./lib/integrations-gemini-ai/src/*"],
      "@workspace/api-client-react": ["./lib/api-client-react/src/index.ts"],
      "@workspace/api-client-react/*": ["./lib/api-client-react/src/*"],
      "@workspace/api-spec": ["./lib/api-spec/src/index.ts"],
      "@workspace/api-zod": ["./lib/api-zod/src/index.ts"],
      "@workspace/*": ["./lib/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "lib/**/node_modules",
    ".next/dev/types/validator.ts",
    "lib/api-spec/orval.config.ts",
    "lib/db/drizzle.config.ts",
    "tests/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "jest.config.ts",
    "jest.setup.ts",
    "playwright.config.ts"
  ]
}
